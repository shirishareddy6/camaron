# ─── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# ─── Database ─────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=camaron
POSTGRES_USER=camaron_user
POSTGRES_PASSWORD=change_this_password
POSTGRES_POOL_MAX=20
POSTGRES_POOL_IDLE=10000
POSTGRES_POOL_ACQUIRE=30000

# ─── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=change_this_jwt_secret_min_64_chars_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_min_64_chars_long
JWT_REFRESH_EXPIRES_IN=7d

# ─── OTP ──────────────────────────────────────────────
OTP_EXPIRES_MINUTES=10
OTP_LENGTH=6

# ─── SMS (Twilio or MSG91) ────────────────────────────
SMS_PROVIDER=twilio            # twilio | msg91
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

MSG91_API_KEY=your_msg91_key
MSG91_SENDER_ID=CAMARN
MSG91_TEMPLATE_ID=your_template_id

# ─── Email (Brevo) ────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM=noreply@camaron.in
EMAIL_FROM_NAME=Camaron

# ─── App ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ─── Logging ──────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
